{
  "name": "gatekeeper",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "NODE_OPTIONS=--experimental-strip-types oxfmt .",
    "format:check": "NODE_OPTIONS=--experimental-strip-types oxfmt --check .",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "25.8.0"
  },
  "packageManager": "pnpm@10.33.0"
}
