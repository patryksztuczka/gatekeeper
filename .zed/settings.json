{
  "lsp": {
    "oxlint": {
      "binary": {
        "path": "pnpm",
        "arguments": ["exec", "oxlint", "--lsp"],
        "env": {
          "NODE_OPTIONS": "--experimental-strip-types"
        }
      },
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "binary": {
        "path": "pnpm",
        "arguments": ["exec", "oxfmt", "--lsp"],
        "env": {
          "NODE_OPTIONS": "--experimental-strip-types"
        }
      },
      "initialization_options": {
        "settings": {
          "fmt.configPath": null,
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "JavaScript": {
      "language_servers": ["oxlint", "!eslint", "..."],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        },
        {
          "code_action": "source.fixAll.oxc"
        }
      ]
    },
    "JSX": {
      "language_servers": ["oxlint", "!eslint", "..."],
