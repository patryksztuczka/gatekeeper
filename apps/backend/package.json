{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "check-types": "tsc --noEmit",
    "lint": "NODE_OPTIONS=--experimental-strip-types pnpm -w exec oxlint . --deny-warnings",
    "lint:fix": "NODE_OPTIONS=--experimental-strip-types pnpm -w exec oxlint . --fix",
    "format": "NODE_OPTIONS=--experimental-strip-types oxfmt .",
    "format:check": "NODE_OPTIONS=--experimental-strip-types oxfmt --check .",
    "test": "vitest run",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.83.0"
  }
}
