# Cloudflare D1 tooling
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_DATABASE_ID=your-d1-database-id
CLOUDFLARE_D1_TOKEN=your-cloudflare-api-token-with-d1-access

# Better Auth and local Worker runtime
BETTER_AUTH_SECRET=generate-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:8787
TRUSTED_ORIGINS=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Local email delivery through Mailpit
MAIL_FROM_EMAIL=no-reply@gatekeeper.local
MAIL_FROM_NAME=Gatekeeper
MAILPIT_URL=http://127.0.0.1:8025
